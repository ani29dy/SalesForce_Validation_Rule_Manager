# Local development
PORT=5000
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your_salesforce_connected_app_client_id
SF_CLIENT_SECRET=your_salesforce_connected_app_client_secret
SF_CALLBACK_URL=http://localhost:5000/auth/callback
SESSION_SECRET=your_random_session_secret_here
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Render production example (set in Render dashboard, not in .env file):
# SF_CALLBACK_URL=https://validation-rule-manager-api.onrender.com/auth/callback
# FRONTEND_URL=https://validation-rule-manager-ui.onrender.com
# NODE_ENV=production
# PORT is set automatically by Render — do not set it manually
